secret_key: 'random-secret-key'
concurrent: 3
storage: /storage
database: postgresql+psycopg2://postgres:postgres@192.168.1.2:5432/jindai

plugins:
- '*'

oidc_secrets: 'oidc-secrets.json'

redis:
  host: localhost
  port: 6379
  db: 0

embedding_model: 'BAAI/bge-m3'
embdding_dims: 1024

ui_dist: ./dist/
paddle_remote: http://paddle-ocr:8080/

# CORS configuration - list of allowed origins (use "*" to allow all)
cors_origins:
  - "*"

# Bibliography plugin configuration
# BibliographyPlugin:
#   calibre_library_paths:
#     - /path/to/calibre/library1
#     - /path/to/calibre/library2
#   zotero_api_key: your_zotero_api_key_here
#   zotero_library_id: your_zotero_library_id_here
#   zotero_library_type: user  # or 'group' for group libraries
